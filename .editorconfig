root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{kt,kts}]
# ktlint reads its rules from here.
ktlint_code_style = intellij_idea
max_line_length = 120

# @Composable functions are PascalCase by convention — don't flag them.
ktlint_function_naming_ignore_when_annotated_with = Composable

# Compose previews / test helpers also use PascalCase.
ktlint_standard_function-naming = enabled

[*.{yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
