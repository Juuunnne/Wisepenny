TEAM_ID=

PRODUCT_NAME=Wisepenny
PRODUCT_BUNDLE_IDENTIFIER=com.example.wisepenny.Wisepenny$(TEAM_ID)

CURRENT_PROJECT_VERSION=1
MARKETING_VERSION=1.0

// SQLDelight's iOS driver (NativeSqliteDriver) calls into the system SQLite C
// library. With a static Kotlin framework, the app must link libsqlite3 itself,
// otherwise every _sqlite3_* symbol is undefined at link time.
OTHER_LDFLAGS=$(inherited) -lsqlite3